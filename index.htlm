<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>Bomb Boom</title>

<style>
body{
    margin:0;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:#222;
    font-family:Arial;
    overflow:hidden;
}

/* KHUNG NGOÀI BO TRÒN */
.outer{
    width:320px;
    height:440px;
    background:black;
    border:4px solid #555;
    border-radius:25px;
    display:flex;
    justify-content:center;
    align-items:center;
}

/* KHUNG TRONG BO TRÒN */
.inner{
    width:85%;
    height:88%;
    background:black;
    border:2px solid #999;
    border-radius:20px;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    gap:18px;
}

/* bomb */
.bomb{
    font-size:60px;
}

/* timer */
.time{
    font-size:32px;
    color:white;
}

/* button */
.btn{
    background:red;
    color:white;
    padding:10px 18px;
    border-radius:12px;
    cursor:pointer;
    font-weight:bold;
}

/* màn nổ */
.explosion{
    position:fixed;
    inset:0;
    display:none;
    overflow:hidden;
    background:black;
}

/* 💥 bay khắp màn hình */
.boom{
    position:absolute;
    font-size:40px;
    animation: float 1.2s linear infinite;
}

/* hiệu ứng bay lung tung */
@keyframes float{
    0%{
        transform:translate(0,0) scale(0.8);
        opacity:1;
    }
    100%{
        transform:translate(200px,-200px) scale(1.5);
        opacity:0;
    }
}
</style>
</head>

<body>

<div class="outer">
    <div class="inner">

        <div class="bomb">💣</div>

        <div class="time" id="time">00:05</div>

        <div class="btn" onclick="start()">KÍCH HOẠT</div>

    </div>
</div>

<!-- MÀN NỔ -->
<div class="explosion" id="boom"></div>

<script>

let t = 5;
let timer;

function start(){

    if(timer) return;

    timer = setInterval(()=>{
        t--;

        document.getElementById("time").innerText =
            "00:0" + t;

        if(t <= 0){
            clearInterval(timer);
            explode();
        }

    },1000);
}

function explode(){

    const boom = document.getElementById("boom");
    boom.style.display = "block";

    // tạo nhiều 💥 khắp màn hình
    for(let i = 0; i < 40; i++){

        let b = document.createElement("div");
        b.className = "boom";
        b.innerText = "💥";

        b.style.left = Math.random() * window.innerWidth + "px";
        b.style.top = Math.random() * window.innerHeight + "px";

        b.style.animationDuration = (0.5 + Math.random()) + "s";

        boom.appendChild(b);
    }
}

</script>

</body>
</html>
